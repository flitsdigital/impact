NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — used by lib/supabase/admin.ts for the public preview page
# en de AI-assistent (/api/assistant). Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI-assistent (Telegram → n8n → /api/assistant) — OpenAI-compatibel, default Groq (gratis).
# Groq-sleutel: https://console.groq.com/keys  (begint met gsk_...)
AI_API_KEY=your-groq-or-other-key
# Default Groq. Voor Gemini: https://generativelanguage.googleapis.com/v1beta/openai
#            Voor OpenAI: https://api.openai.com/v1
AI_BASE_URL=https://api.groq.com/openai/v1
# Default Groq-model. Gemini bv. gemini-2.0-flash; OpenAI bv. gpt-4o-mini.
AI_MODEL=llama-3.3-70b-versatile
# Gedeeld geheim: n8n stuurt dit mee als header x-assistant-secret. Verzin een lange random string.
ASSISTANT_WEBHOOK_SECRET=your-long-random-secret

# Todo-API (/api/todos) — server-to-server, bv. vanuit n8n. Stuur mee als header
# x-api-secret. Verzin een lange random string. Gebruikt SUPABASE_SERVICE_ROLE_KEY.
TODOS_API_SECRET=your-long-random-secret
